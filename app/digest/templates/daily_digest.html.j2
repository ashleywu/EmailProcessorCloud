<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{{ title | e }}</title>
  <style>
    body { font-family: system-ui, sans-serif; line-height: 1.5; color: #1a1a1a; max-width: 720px; margin: 0 auto; padding: 1rem; }
    h1 { font-size: 1.35rem; border-bottom: 1px solid #ddd; padding-bottom: 0.5rem; }
    h2 { font-size: 1.1rem; margin-top: 1.5rem; color: #333; }
    .note { background: #f6f8fa; border-left: 3px solid #0969da; padding: 0.75rem 1rem; margin: 1rem 0; font-size: 0.9rem; }
    .item { margin: 0.75rem 0; padding-bottom: 0.75rem; border-bottom: 1px solid #eee; }
    .story-block { margin: 0.6rem 0 0 0; }
    .sub { font-size: 0.85rem; color: #555; }
    ul { margin: 0.25rem 0; padding-left: 1.2rem; }
  </style>
</head>
<body>
{% if quality_notes %}
  <div class="note"><strong>Revision notes:</strong> {{ quality_notes | e }}</div>
{% endif %}
<h1>{{ title | e }}</h1>

<h2>Technical Index</h2>
{% if technical_index %}
  {% for it in technical_index %}
  <div class="item">
    {% if it.section_heading %}<div class="sub"><strong>{{ it.section_heading | e }}</strong></div>{% endif %}
    <div><strong>{{ it.email_subject | e }}</strong></div>
    {% if it.source_sender %}<div class="sub">From: {{ it.source_sender | e }}</div>{% endif %}
    {% if it.title %}
      <div class="story-block">
        {% if it.article_url %}
          <div><a href="{{ it.article_url | e }}">{{ it.title | e }}</a></div>
        {% else %}
          <div>{{ it.title | e }}</div>
        {% endif %}
        <div>{{ it.core_pain_point | e }}</div>
      </div>
    {% endif %}
    {% if it.diagrams %}
      {% for dg in it.diagrams %}
        <pre class="sub">{{ dg.diagram_type | e }} · {{ dg.title | e }}

{{ dg.content | e }}</pre>
      {% endfor %}
    {% endif %}
  </div>
  {% endfor %}
{% else %}
  <p class="sub">No items in this section.</p>
{% endif %}

<h2>AI Radar</h2>
{% if ai_radar %}
  {% for it in ai_radar %}
  <div class="item">
    {% if it.section_heading %}<div class="sub"><strong>{{ it.section_heading | e }}</strong></div>{% endif %}
    <div><strong>{{ it.subject | e }}</strong></div>
    {% if it.source_sender %}<div class="sub">From: {{ it.source_sender | e }}</div>{% endif %}
    {% if it.summary %}<div class="sub">{{ it.summary | e }}</div>{% endif %}
    <ul>
    {% for row in it['items'] %}
      <li>{{ row.entity | e }} — {{ row.impact_or_action | e }}{% if row.url %} (<a href="{{ row.url | e }}">{{ row.url | e }}</a>){% endif %}</li>
    {% endfor %}
    </ul>
  </div>
  {% endfor %}
{% else %}
  <p class="sub">No items in this section.</p>
{% endif %}

<h2>Leadership Signals</h2>
{% if leadership_signals %}
  {% for it in leadership_signals %}
  <div class="item">
    {% if it.section_heading %}<div class="sub"><strong>{{ it.section_heading | e }}</strong></div>{% endif %}
    <div><strong>{{ it.subject | e }}</strong></div>
    {% if it.source_sender %}<div class="sub">From: {{ it.source_sender | e }}</div>{% endif %}
    {% if it.summary %}<div class="sub">{{ it.summary | e }}</div>{% endif %}
    <ul>
    {% for s in it.signals %}
      <li><strong>{{ s.theme | e }}</strong>: {{ s.insight | e }}; Action: {{ s.actionable_item | e }}{% if s.link %} · <a href="{{ s.link | e }}">link</a>{% endif %}</li>
    {% endfor %}
    </ul>
  </div>
  {% endfor %}
{% else %}
  <p class="sub">No items in this section.</p>
{% endif %}

<h2>Courses &amp; Promotions</h2>
{% if courses %}
  {% for it in courses %}
  <div class="item">
    {% if it.section_heading %}<div class="sub"><strong>{{ it.section_heading | e }}</strong></div>{% endif %}
    {% if it.subject %}<div><strong>{{ it.subject | e }}</strong></div>{% endif %}
    {% if it.source_sender %}<div class="sub">From: {{ it.source_sender | e }}</div>{% endif %}
    <div class="sub">Source: {{ it.source_subject | e }}</div>
    {% if it.promo_blocks %}
      {% if (it.summary or '').strip() %}
        {% for line in (it.summary or '').splitlines() %}
          {% if line %}<p>{{ line | e }}</p>{% endif %}
        {% endfor %}
      {% endif %}
      <ul class="actions">
        {% for block in it.promo_blocks %}
        <li>{{ block.text | e }} (<a href="{{ block.cta.url | e }}">{{ block.cta.label | e }}</a>)</li>
        {% endfor %}
      </ul>
      {% if it.actions %}
      <ul class="actions">
        {% for a in it.actions %}
        <li><a href="{{ a.url | e }}">{{ a.label | e }}</a></li>
        {% endfor %}
      </ul>
      {% endif %}
    {% else %}
    {% for line in (it.summary or '').splitlines() %}
      {% if line %}<p>{{ line | e }}</p>{% endif %}
    {% endfor %}
    {% if it.actions %}
    <ul class="actions">
      {% for a in it.actions %}
      <li><a href="{{ a.url | e }}">{{ a.label | e }}</a></li>
      {% endfor %}
    </ul>
    {% endif %}
    {% endif %}
  </div>
  {% endfor %}
{% else %}
  <p class="sub">No items in this section.</p>
{% endif %}

<p class="sub">Automated daily digest.</p>
</body>
</html>
