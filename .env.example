# SQLite database file path
DAILY_DIGEST_DB_PATH=./data/daily_digest.db

# Run lock (defaults shown)
DAILY_DIGEST_LOCK_NAME=daily_digest_agent
DAILY_DIGEST_LOCK_TTL_MINUTES=60

# Retry policy for fetch_retryable_errors
DAILY_DIGEST_MAX_EMAIL_RETRIES=3

# Gmail integration (Milestone 2)
# Comma-separated list of newsletter sender addresses to scan.
NEWSLETTER_SENDERS=newsletter@example.com,digest@anothernews.com
# Where to deliver the assembled daily digest.
DIGEST_RECIPIENT_EMAIL=you@example.com
# OAuth client secrets downloaded from Google Cloud console.
GMAIL_CREDENTIALS_PATH=./secrets/credentials.json
# Token cache produced by the first OAuth flow.
GMAIL_TOKEN_PATH=./secrets/token.json
# How many days back the fetcher looks (48h = 2 days).
GMAIL_LOOKBACK_DAYS=2
