# OpenAI — required for ``python -m app.main run-daily`` (not required for ``preview-digest``)
OPENAI_API_KEY=
ROUTER_MODEL=gpt-4o-mini
PROCESSOR_MODEL=gpt-4o-mini

# SQLite database file path
DAILY_DIGEST_DB_PATH=./data/daily_digest.db

# Run lock (defaults shown)
DAILY_DIGEST_LOCK_NAME=daily_digest_agent
DAILY_DIGEST_LOCK_TTL_MINUTES=60

# Retry policy for fetch_retryable_errors
DAILY_DIGEST_MAX_EMAIL_RETRIES=3

# Quality gate: max compose → check rounds (includes first draft)
DAILY_DIGEST_MAX_QUALITY_GATE_ATTEMPTS=3

# Gmail integration
# Comma-separated allowlist fed into Gmail ``messages.list`` as ``from:`` clauses.
# Example: NEWSLETTER_SENDERS=reading@publisher.com,@publisher.com
# (second form is shorthand for any subdomain of publisher.com Gmail shows.)
NEWSLETTER_SENDERS=newsletter@publisher.com,@publisher.com
# Where to deliver the assembled daily digest (required for run-daily).
DIGEST_RECIPIENT_EMAIL=you@example.com
# OAuth client secrets downloaded from Google Cloud console.
GMAIL_CREDENTIALS_PATH=./secrets/credentials.json
# Token cache produced by the first OAuth flow.
GMAIL_TOKEN_PATH=./secrets/token.json
# How many days back the fetcher looks (48h = 2 days).
GMAIL_LOOKBACK_DAYS=2
