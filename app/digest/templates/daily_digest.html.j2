<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{{ title | e }}</title>
  <style>
    body { font-family: system-ui, sans-serif; line-height: 1.5; color: #1a1a1a; max-width: 720px; margin: 0 auto; padding: 1rem; }
    h1 { font-size: 1.35rem; border-bottom: 1px solid #ddd; padding-bottom: 0.5rem; }
    h2 { font-size: 1.1rem; margin-top: 1.5rem; color: #333; }
    .note { background: #f6f8fa; border-left: 3px solid #0969da; padding: 0.75rem 1rem; margin: 1rem 0; font-size: 0.9rem; }
    .item { margin: 0.75rem 0; padding-bottom: 0.75rem; border-bottom: 1px solid #eee; }
    .story-block { margin: 0.6rem 0 0 0; }
    .sub { font-size: 0.85rem; color: #555; }
    ul { margin: 0.25rem 0; padding-left: 1.2rem; }
  </style>
</head>
<body>
{% if quality_notes %}
  <div class="note"><strong>Revision notes:</strong> {{ quality_notes | e }}</div>
{% endif %}
<h1>{{ title | e }}</h1>

<h2>Technical Index</h2>
{% if technical_index %}
  {% for it in technical_index %}
  <div class="item">
    <div><strong>{{ it.subject | e }}</strong></div>
    {% if it.source_sender %}<div class="sub">From: {{ it.source_sender | e }}</div>{% endif %}
    {% if it.stories %}
      {% for story in it.stories %}
      <div class="story-block">
        <div><a href="{{ story.article_url | e }}">{{ story.title | e }}</a></div>
        <div>{{ story.summary | e }}</div>
        <div class="sub">Source: {{ story.source_subject | e }}{% if story.source_sender %} · From: {{ story.source_sender | e }}{% endif %}</div>
        {% if story.newsletter_original_url %}
        <div class="sub"><a href="{{ story.newsletter_original_url | e }}">Newsletter web version</a></div>
        {% endif %}
      </div>
      {% endfor %}
    {% elif it.core_pain_point %}
      <div>{{ it.core_pain_point | e }}</div>
      {% if it.digest_source_url %}
      <div class="sub"><a href="{{ it.digest_source_url | e }}">Web version</a></div>
      {% endif %}
      <div class="sub">Source: {{ it.subject | e }}{% if it.source_sender %} · From: {{ it.source_sender | e }}{% endif %}</div>
    {% endif %}
  </div>
  {% endfor %}
{% else %}
  <p class="sub">No items in this section.</p>
{% endif %}

<h2>AI Radar</h2>
{% if ai_radar %}
  {% for it in ai_radar %}
  <div class="item">
    <div><strong>{{ it.subject | e }}</strong></div>
    {% if it.source_sender %}<div class="sub">From: {{ it.source_sender | e }}</div>{% endif %}
    {% if it.summary %}<div class="sub">{{ it.summary | e }}</div>{% endif %}
    <ul>
    {% for row in it['items'] %}
      <li>{{ row.entity | e }} — {{ row.impact_or_action | e }}{% if row.url %} (<a href="{{ row.url | e }}">{{ row.url | e }}</a>){% endif %}<div class="sub">Source: {{ row.source_subject | e }}{% if row.source_sender %} · From: {{ row.source_sender | e }}{% endif %}</div></li>
    {% endfor %}
    </ul>
  </div>
  {% endfor %}
{% else %}
  <p class="sub">No items in this section.</p>
{% endif %}

<h2>Leadership Signals</h2>
{% if leadership_signals %}
  {% for it in leadership_signals %}
  <div class="item">
    <div><strong>{{ it.subject | e }}</strong></div>
    {% if it.source_sender %}<div class="sub">From: {{ it.source_sender | e }}</div>{% endif %}
    {% if it.summary %}<div class="sub">{{ it.summary | e }}</div>{% endif %}
    <ul>
    {% for s in it.signals %}
      <li><strong>{{ s.theme | e }}</strong>: {{ s.insight | e }}; Action: {{ s.actionable_item | e }}{% if s.link %} · <a href="{{ s.link | e }}">link</a>{% endif %}<div class="sub">Source: {{ s.source_subject | e }}{% if s.source_sender %} · From: {{ s.source_sender | e }}{% endif %}</div></li>
    {% endfor %}
    </ul>
  </div>
  {% endfor %}
{% else %}
  <p class="sub">No items in this section.</p>
{% endif %}

<h2>Filtered Noise</h2>
{% if filtered_noise %}
  {% for it in filtered_noise %}
  <div class="item">
    <div class="sub">Source: {{ it.source_subject | e }}{% if it.source_sender %} · From: {{ it.source_sender | e }}{% endif %}</div>
    <div>{{ it.reason | e }}</div>
  </div>
  {% endfor %}
{% else %}
  <p class="sub">No items in this section.</p>
{% endif %}

<p class="sub">Automated daily digest.</p>
</body>
</html>
